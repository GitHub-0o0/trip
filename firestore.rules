rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net - Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Validation helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming(request) {
      return request.resource.data;
    }

    function existing(resource) {
      return resource.data;
    }

    // 2. Rules for Multi-device Sync Plans
    match /sync_plans/{planId} {
      allow get: if isValidId(planId);
      allow list: if false; // Block user bulk scraping queries
      
      allow create: if isValidId(planId)
        && incoming(request).id is string
        && incoming(request).code is string
        && incoming(request).code.size() == 6
        && incoming(request).tripPlan is map;
        
      allow update: if isValidId(planId)
        && incoming(request).code == existing(resource).code
        && incoming(request).tripPlan is map;
        
      allow delete: if false; // Prevent client side accidental deletions
    }
  }
}
